---
// Este componente está preparado para montar un modelo 3D usando Three.js, Spline, o @react-three/fiber.
---

<section id="modelo-3d" class="relative snap-start w-full h-screen bg-white overflow-hidden flex items-center justify-center border-t border-zinc-200 z-10">
  
  <!-- Contenedor del Canvas 3D -->
  <!-- escena de WebGL o Spline -->
  <div class="absolute inset-0 z-10 flex items-center justify-center pointer-events-none">
    <div class="w-[80%] max-w-4xl h-[70%] cursor-grab active:cursor-grabbing pointer-events-auto" id="canvas-container">
      <canvas id="car-canvas" class="w-full h-full outline-none"></canvas>
    </div>
  </div>

  <!-- Luces / Gradientes de fondo decorativos (Ajustados para fondo blanco) -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-rose-200/40 rounded-full blur-[128px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-zinc-200/50 rounded-full blur-[128px]"></div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-white to-transparent"></div>
    <div class="absolute inset-x-0 top-0 h-1/4 bg-gradient-to-b from-white to-transparent"></div>
  </div>

  <!-- UI Superpuesta (Overlay) -->
  <div class="relative z-20 container mx-auto px-6 h-full flex flex-col justify-between py-24 pointer-events-none">
    
    <!-- Título Principal -->
    <div class="text-center mt-12 md:mt-0">
      <h2 class="text-xs font-bold tracking-widest text-rose-600 uppercase mb-3">Vista 360° Interactiva</h2>
      <h3 class="text-4xl md:text-5xl font-extrabold text-zinc-900 tracking-tight">Explora cada detalle</h3>
      <p class="text-zinc-600 mt-4 max-w-xl mx-auto font-medium">Interactúa con nuestro modelo de alto rendimiento. Arrastra para rotar.</p>
    </div>

    <!-- Controles / Metadatos en la parte inferior -->
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 pb-12">
      <!-- Datos Técnicos -->
      <div class="bg-white/80 backdrop-blur-md border border-zinc-200 rounded-2xl p-6 pointer-events-auto shadow-[0_8px_30px_rgb(0,0,0,0.08)]">
        <h4 class="text-zinc-900 font-bold text-xl mb-4 flex items-center gap-2">
          <span>Informacion</span>
          <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
        </h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center gap-12">
            <span class="text-zinc-500 text-sm">Color</span>
            <div class="flex items-center gap-2" id="color-picker" style="pointer-events: auto;">
              <!-- Botones de Color Interactivos -->
              <button class="color-btn w-6 h-6 rounded-full bg-[#111111] border-2 border-white/50 hover:scale-110 transition-transform focus:outline-none focus:border-white" data-color="#111111" aria-label="Negro"></button>
              <button class="color-btn w-6 h-6 rounded-full bg-[#E11D48] border-2 border-transparent hover:scale-110 transition-transform focus:outline-none focus:border-white" data-color="#E11D48" aria-label="Rojo" style="box-shadow: inset 0 2px 4px rgba(255,255,255,0.3);"></button>
              <button class="color-btn w-6 h-6 rounded-full bg-[#E5E7EB] border-2 border-transparent hover:scale-110 transition-transform focus:outline-none focus:border-white" data-color="#E5E7EB" aria-label="Plata"></button>
              <button class="color-btn w-6 h-6 rounded-full bg-[#1E3A8A] border-2 border-transparent hover:scale-110 transition-transform focus:outline-none focus:border-white" data-color="#1E3A8A" aria-label="Azul"></button>
            </div>
          </div>
          <div class="flex justify-between items-center gap-12 pt-3 border-t border-zinc-100">
            <span class="text-zinc-500 text-sm font-medium">Llantas</span>
            <span class="text-zinc-900 font-semibold text-sm">Tipo de llantas</span>
          </div>
          <div class="flex justify-between items-center gap-12 pt-3 border-t border-zinc-100">
            <span class="text-zinc-500 text-sm font-medium">Interior</span>
            <span class="text-zinc-900 font-semibold text-sm">Tipo de interior</span>
          </div>
        </div>
      </div>

      <!-- Hint para el usuario -->
      <div class="hidden md:flex items-center gap-3 bg-zinc-100/80 backdrop-blur-sm border border-zinc-200 px-5 py-3 rounded-full pointer-events-auto shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-zinc-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zm-7.518-.267A8.25 8.25 0 1120.25 10.5M8.288 14.212A5.25 5.25 0 1117.25 10.5" />
        </svg>
        <span class="text-xs text-zinc-600 font-semibold">Click y Arrastra para Rotar</span>
      </div>
    </div>
  </div>

</section>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';


  if (typeof window !== 'undefined') {
    const canvas = document.getElementById('car-canvas') as HTMLCanvasElement;
    const container = document.getElementById('canvas-container');

    if (canvas && container) {
      // 1. Configurar la Escena
      const scene = new THREE.Scene();

      // 2. Configurar la Camara
      const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 100);
      camera.position.set(3, 2, 5); // Acercarse al modelo (ajustar según el tamaño del .glb)

      // 3. Configurar el Renderizador
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      // Importante para colores realistas en formatos glTF
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.6; // Aumentado para mayor brillo general

      // 4. Configurar Controles (OrbitControls)
      const controls = new OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 2.0;
      controls.enableZoom = false;

      // 5. Luces (Incrementadas para el fondo blanco)
      const ambientLight = new THREE.AmbientLight(0xffffff, 1.5); // Luz de ambiente más fuerte
      scene.add(ambientLight);

      const mainLight = new THREE.DirectionalLight(0xffffff, 3.5); // Luz principal más brillante
      mainLight.position.set(5, 10, 7);
      scene.add(mainLight);

      const fillLight = new THREE.DirectionalLight(0xffaaee, 1); // Luz de relleno con un toque rosado/rojo 
      fillLight.position.set(-5, 0, -5);
      scene.add(fillLight);

      const rimLight = new THREE.PointLight(0xff0000, 2, 20); // Acento rojo sutil
      rimLight.position.set(0, -1, -5);
      scene.add(rimLight);

      // 6. Cargar el Modelo .GLB
      const loader = new GLTFLoader();
      
      // *** ruta del archivo public/modelos/tu_carro.glb ***
      loader.load(
        '/modelos/carro.glb', // ruta real de tu archivo en "public/modelos/"
        (gltf) => {
          const model = gltf.scene;

          // Centrar el modelo en el origen, por si el origen de Blender está movido
          const box = new THREE.Box3().setFromObject(model);
          const center = box.getCenter(new THREE.Vector3());
          model.position.sub(center);

          // Guardar una referencia a TODOS los materiales de pintura encontrados
          const paintMaterials: THREE.Material[] = [];

          model.traverse((child) => {
            if (child.isMesh && child.material) {
              const matName = child.material.name.toLowerCase();
              // A veces la carrocería usa 'paint', o 'coat'. Filtraremos por 'paint'
              if (matName.includes('paint')) {
                const mat = child.material as THREE.MeshStandardMaterial;
                
                // Si este material específico aún no está en nuestro arreglo, lo agregamos
                if (!paintMaterials.includes(mat)) {
                  paintMaterials.push(mat);
                  // Ajustar propiedades para que brille como pintura
                  mat.roughness = 0.2;
                  mat.metalness = 0.6;
                }
              }
            }
          });

          // Configurar los botones de color de la UI
          const colorButtons = document.querySelectorAll('.color-btn');
          colorButtons.forEach((btn) => {
            btn.addEventListener('click', (e) => {
              const target = e.currentTarget as HTMLButtonElement;
              const colorHex = target.getAttribute('data-color');
              
              if (colorHex && paintMaterials.length > 0) {
                // Actualizar el estilo de los botones (marcar el activo)
                colorButtons.forEach(b => {
                  (b as HTMLElement).style.borderColor = 'transparent';
                });
                target.style.borderColor = 'rgba(255, 255, 255, 0.8)';

                // Animar la transición de color para TODOS los pedazos de pintura encontrados
                const targetColor = new THREE.Color(colorHex);
                paintMaterials.forEach(mat => {
                  (mat as THREE.MeshStandardMaterial).color.set(targetColor);
                });
              }
            });
          });

          // Ajustar tamaño del modelo (opcional)
          // model.scale.set(0.5, 0.5, 0.5);

          scene.add(model);
        },
        undefined, // Función para progreso (opcional)
        (error) => {
          console.error("No se pudo cargar el modelo 3D", error);
        }
      );

      // 7. Manejo del redimensionamiento (Responsive)
      window.addEventListener('resize', () => {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      });

      // 8. Bucle de Animación
      const animate = function () {
        requestAnimationFrame(animate);
        controls.update(); // Necesario para el damping y rotación automática
        renderer.render(scene, camera);
      };

      animate();
    }
  }
</script>
