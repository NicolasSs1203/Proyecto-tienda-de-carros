---
---

<section class="relative snap-start h-screen w-full flex items-center justify-center overflow-hidden z-0">
  <!-- Dynamic Background Video Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-zinc-950/30 z-10"></div>
    <video 
      autoplay 
      loop 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover opacity-60"
    >
      <source src="/videos/Video_de_Carro_en_Movimiento.mp4" type="video/mp4" />
      <!-- Fallback message for older browsers -->
      Your browser does not support the video tag.
    </video>
  </div>

  <div class="relative z-20 container mx-auto px-6 text-center max-w-4xl pt-20">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 backdrop-blur-md mb-8">
      <span class="flex h-2 w-2 rounded-full bg-rose-500"></span>
      <span class="text-xs font-medium tracking-wide uppercase text-zinc-300">alert</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight text-white mb-6 leading-tight drop-shadow-2xl">
      Carros <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-400 to-rose-600">Motors</span>
    </h1>
    
    <p class="text-lg md:text-xl text-zinc-400 mb-10 max-w-2xl mx-auto leading-relaxed">
    
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/inventario" class="px-8 py-4 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-full transition-all duration-300 transform hover:scale-105 hover:shadow-[0_0_20px_rgba(225,29,72,0.4)] w-full sm:w-auto">
        Explorar Modelos
      </a>
    </div>
  </div>

  <!-- Decorative bottom gradient to blend into next section -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-zinc-950 to-transparent z-20 pointer-events-none"></div>
</section>

<style>
  /* Optional: Keep style tags if you add more specific styles later */
</style>
