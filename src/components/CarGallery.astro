---
const response = await fetch('https://proyecto-tienda-de-carros.onrender.com/api/vehicles');
const cars = await response.json();

// Mapear al mismo formato para no romper componentes existentes
const formattedCars = cars.map((car: any) => ({
  id: car.id,
  make: car.brand,
  model: car.model,
  year: car.year,
  price: new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 }).format(car.price),
  specs: car.description,
  image: car.imageUrl
}));
---
<section id="inventory" class="flex-1 relative w-full overflow-hidden bg-transparent flex flex-col justify-center pb-12 sm:pb-32">
  <div class="max-w-[1400px] w-full mx-auto px-6 flex flex-col h-full justify-center">

    <!-- Collection Carousel -->
    <div class="relative w-full -mx-6 px-6 sm:mx-0 sm:px-0 flex-1 flex flex-col justify-center min-h-[500px]">
      <!-- Left Fade -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-black/60 to-transparent z-10 pointer-events-none hidden md:block"></div>
      
      <!-- Left Arrow Button -->
      <button id="btn-prev" class="absolute left-4 sm:-left-6 top-1/2 -translate-y-1/2 z-20 bg-zinc-900/80 hover:bg-rose-600 text-white w-12 h-12 flex items-center justify-center rounded-full border border-white/10 hover:border-transparent transition-all shadow-xl backdrop-blur-md opacity-0 group-hover:opacity-100 md:opacity-100 hidden md:flex cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <!-- Right Fade -->
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-black/60 to-transparent z-10 pointer-events-none hidden md:block"></div>

      <!-- Right Arrow Button -->
      <button id="btn-next" class="absolute right-4 sm:-right-6 top-1/2 -translate-y-1/2 z-20 bg-zinc-900/80 hover:bg-rose-600 text-white w-12 h-12 flex items-center justify-center rounded-full border border-white/10 hover:border-transparent transition-all shadow-xl backdrop-blur-md hidden md:flex cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <div id="carousel-track" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-6 pt-2 scrollbar-hide h-full items-center smooth-scroll" style="scrollbar-width: none; -ms-overflow-style: none;">
        {formattedCars.map((car: any) => (
          <div class="relative bg-white/20 backdrop-blur-md border border-white/40 rounded-2xl overflow-hidden flex-none w-[90vw] sm:w-[500px] snap-center">
            <div class="aspect-[16/10] overflow-hidden relative">
            <img 
              src={`${car.image}?q=80&w=800&auto=format&fit=crop`} 
              alt={`${car.year} ${car.make} ${car.model}`}
              class="object-cover w-full h-full"
              loading="lazy"
            />
            <div class="absolute top-4 left-4 z-20 bg-black/40 backdrop-blur-md px-3 py-1 rounded-full text-xs font-extrabold text-white border border-white/20 shadow-sm">
              {car.year} New
            </div>
          </div>
          <div class="p-6 relative z-20">
            <p class="text-sm text-zinc-200 font-bold uppercase tracking-wider mb-1 drop-shadow-md">{car.make}</p>
            <h4 class="text-2xl font-black text-white tracking-tight mb-2 drop-shadow-md">{car.model}</h4>
            <p class="text-rose-400 font-bold mb-6 flex items-center justify-between">
              <span class="text-xl drop-shadow-md">{car.price}</span>
            </p>
            <div class="mb-6 pt-4 border-t border-white/20">
              <p class="text-xs text-zinc-100 font-bold font-mono tracking-wide line-clamp-2 min-h-[32px] drop-shadow-md">{car.specs}</p>
            </div>
            <a href={`/auto/${car.id}`} class="block w-full py-3 bg-white/10 hover:bg-rose-600 text-white text-center text-sm font-bold rounded-xl transition-colors duration-300 outline-none shadow-sm backdrop-blur-sm border border-white/20 hover:border-transparent">
              Ver Detalles
            </a>
          </div>
        </div>
      ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Ocultar barra de scroll para navegadores webkit (Chrome, Safari) */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  .smooth-scroll {
    scroll-behavior: smooth;
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    const track = document.getElementById('carousel-track');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');

    // Desplazar aproximadamente el ancho de la tarjeta más el gap (500 + 24)
    const scrollAmount = 500 + 24; 

    if (btnPrev && btnNext && track) {
      btnPrev.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      btnNext.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  }
</script>
