---
import { Image } from 'astro:assets';
import loboLogo from '../assets/loboLogo.png';
---

<header class="fixed w-full top-0 z-50 transition-all duration-300 transparent" id="main-header">
  <div class="w-full mx-auto px-6 h-20 flex items-center justify-between relative">
    <!-- Empty space for flex distribution (optional, keeps layout balanced if there was a left menu) -->
    <div class="w-10"></div>
    
    <!-- Centered Logo -->
    <a href="/" class="absolute left-1/2 -translate-x-1/2 z-50 flex items-center justify-center pointer-events-auto transition-all duration-700" id="main-logo">
      <Image src={loboLogo} alt="Carros Motors" class="h-24 w-auto object-contain drop-shadow-xl" />
    </a>
    
    <!-- Hamburger Menu on the Right -->
    <button id="menu-toggle" class="text-white z-50 cursor-pointer hover:text-rose-500 transition-all duration-700 bg-black/20 p-2 rounded-full backdrop-blur-sm" aria-label="Toggle Menu">
      <!-- Hamburger Icon -->
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 transition-transform duration-300">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <!-- Close Icon (Hidden by default) -->
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 hidden transition-transform duration-300">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Sidebar Menu (Barra lateral derecha) -->
  <div id="dropdown-menu" class="fixed top-0 right-0 h-screen w-80 bg-zinc-950 border-l border-white/5 shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out flex flex-col pt-28 px-8 pb-8 z-40">
    <nav class="flex flex-col gap-8 mb-auto">
      <a href="/" class="menu-link group text-2xl font-bold text-zinc-400 hover:text-white transition-colors flex items-center justify-between">
        Inicio
        <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-rose-500">→</span>
      </a>
      <a href="/inventario" class="menu-link group text-2xl font-bold text-zinc-400 hover:text-white transition-colors flex items-center justify-between">
        Inventario
        <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-rose-500">→</span>
      </a>
      <a href="/#beneficios" class="menu-link group text-2xl font-bold text-zinc-400 hover:text-white transition-colors flex items-center justify-between">
        Beneficios
        <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-rose-500">→</span>
      </a>
      <a href="/#contacto" class="menu-link group text-2xl font-bold text-zinc-400 hover:text-white transition-colors flex items-center justify-between">
        Contacto
        <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-rose-500">→</span>
      </a>
    </nav>

    <div class="flex flex-col gap-4 border-t border-white/10 pt-8 mt-8">
      <a href="/login" class="menu-link text-center text-lg font-medium text-zinc-400 hover:text-white transition-colors">
        Iniciar Sesión
      </a>
      <a href="/inventario" class="menu-link text-center w-full py-4 bg-white text-black text-lg font-bold rounded-xl hover:bg-zinc-200 transition-all duration-300 mt-2">
        Ver Modelos
      </a>
    </div>
  </div>
</header>

<script>
  if (typeof window !== 'undefined') {
    const menuToggle = document.getElementById('menu-toggle');
    const dropdownMenu = document.getElementById('dropdown-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');
    const menuLinks = document.querySelectorAll('.menu-link');

    const toggleMenu = () => {
      const isMenuOpen = !dropdownMenu?.classList.contains('translate-x-full');
      
      if (isMenuOpen) {
        // Close menu
        dropdownMenu?.classList.add('translate-x-full');
        iconClose?.classList.add('hidden');
        iconMenu?.classList.remove('hidden');
      } else {
        // Open menu
        dropdownMenu?.classList.remove('translate-x-full');
        iconMenu?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
    };

    if (menuToggle && dropdownMenu) {
      menuToggle.addEventListener('click', toggleMenu);
      
      // Close menu when clicking any link
      menuLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (!dropdownMenu.classList.contains('translate-x-full')) {
            toggleMenu();
          }
        });
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!dropdownMenu.contains(e.target as Node) && !menuToggle.contains(e.target as Node)) {
          if (!dropdownMenu.classList.contains('translate-x-full')) {
            toggleMenu();
          }
        }
      });
      
      // Manejar colores según la sección activa (Enviado desde index.astro)
      const mainLogo = document.getElementById('main-logo');
      
      window.addEventListener('sectionChange', (e: any) => {
        const sectionIndex = e.detail.index;
        
        if (sectionIndex === 1) { // 1 es la sección del Modelo 3D (Fondo Blanco)
          if (mainLogo) mainLogo.style.filter = 'invert(1)';
          menuToggle.classList.remove('text-white', 'bg-black/20');
          menuToggle.classList.add('text-black', 'bg-black/5');
        } else { // Hero o Footer (Fondos Oscuros)
          if (mainLogo) mainLogo.style.filter = 'invert(0)';
          menuToggle.classList.add('text-white', 'bg-black/20');
          menuToggle.classList.remove('text-black', 'bg-black/5');
        }
      });
    }
  }
</script>
