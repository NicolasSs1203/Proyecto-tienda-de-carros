---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión | CARROS MOTORS">
  <div class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Gradient / Image -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-zinc-950/80 backdrop-blur-sm z-10"></div>
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-30 transform scale-105"></div>
      
      <!-- Decorative Glows -->
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-rose-600/20 rounded-full blur-[128px] z-10"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-rose-900/20 rounded-full blur-[128px] z-10"></div>
    </div>

    <!-- Login Container -->
    <div class="relative z-20 w-full max-w-md px-6 py-12">
      <!-- Back Link -->
      <a href="/" class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors mb-8 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al inicio
      </a>

      <!-- Glassmorphic Card -->
      <div class="bg-zinc-900/50 backdrop-blur-xl border border-white/10 p-8 rounded-3xl shadow-2xl relative overflow-hidden">
        <!-- Top accent line -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-rose-500 to-transparent opacity-50"></div>

        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold tracking-tight text-white mb-2">Bienvenido de nuevo</h1>
          <p class="text-zinc-400 text-sm">Ingresa tus credenciales para acceder a tu cuenta.</p>
        </div>

        <form class="space-y-6">
          <div class="space-y-4">
            <!-- Email Input -->
            <div class="relative">
              <label for="email" class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Correo Electrónico</label>
              <div class="relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  placeholder="tu@correo.com" 
                  class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                  required
                />
              </div>
            </div>

            <!-- Password Input -->
            <div class="relative">
              <div class="flex justify-between items-center mb-1 ml-1">
                <label for="password" class="block text-xs font-medium text-zinc-400">Contraseña</label>
                <a href="#" class="text-xs text-rose-500 hover:text-rose-400 transition-colors">¿Olvidaste tu contraseña?</a>
              </div>
              <div class="relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                </div>
                <input 
                  type="password" 
                  id="password" 
                  name="password" 
                  placeholder="••••••••" 
                  class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                  required
                />
              </div>
            </div>
          </div>

          <button 
            type="submit" 
            class="w-full py-3.5 px-4 bg-rose-600 hover:bg-rose-500 text-white text-sm font-semibold rounded-xl transition-all duration-300 transform shadow-[0_0_15px_rgba(225,29,72,0.3)] hover:shadow-[0_0_25px_rgba(225,29,72,0.5)] flex justify-center items-center gap-2"
          >
            Iniciar Sesión
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>

        <div class="mt-8 text-center">
          <p class="text-xs text-zinc-500">
            ¿No tienes una cuenta? <a href="/registro" class="text-white hover:text-rose-400 font-medium transition-colors">Regístrate</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
