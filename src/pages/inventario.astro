---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CarGallery from '../components/CarGallery.astro';
---

<Layout title="Inventario | CARROS MOTORS">
	<Header />
	<main class="h-screen w-full flex flex-col overflow-hidden pt-20 relative">
		<!-- Imagen de fondo ampliada para ocultar los bordes blancos -->
		<div class="absolute -inset-[2px] bg-[url('/imagenes/fondoOlas.png')] bg-cover bg-center bg-no-repeat scale-[1.08] z-0"></div>
		
		<!-- Dark overlay unificador -->
		<div class="absolute inset-0 bg-zinc-950/80 pointer-events-none z-0"></div>

		<div class="relative z-10 flex-shrink-0">
			<div class="max-w-7xl mx-auto px-6 pt-12 pb-2 text-center">
				<h1 class="text-2xl md:text-4xl font-black text-white tracking-tight drop-shadow-lg">Nuestro <span class="text-rose-500">Inventario</span></h1>
			</div>
		</div>
		<div class="relative z-10 flex-1 flex flex-col">
			<CarGallery />
		</div>
	</main>
</Layout>
