---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

// 1. Verificación de Seguridad SSR (Solo Usuarios Autenticados)
const token = Astro.cookies.get('token')?.value;

if (!token) {
  return Astro.redirect('/login');
}

// 2. Obtener datos del Vehículo
const { id } = Astro.params;
let car = null;

try {
  // En Docker de Azure será http://backend-autos:3001 referenciando el DNS interno. Localmente será localhost.
  const apiUrl = process.env.API_URL || 'http://localhost:3001';
  const response = await fetch(`${apiUrl}/api/vehicles/${id}`);
  if (response.ok) {
    const carData = await response.json();
    car = {
      id: carData.id,
      make: carData.brand,
      model: carData.model,
      year: carData.year,
      price: new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 }).format(carData.price),
      rawPrice: carData.price,
      image: carData.imageUrl
    };
  }
} catch (error) {
  console.error("Error fetching vehicle for checkout:", error);
}

if (!car) {
  return Astro.redirect('/inventario');
}
---

<Layout title={`Procesar Pago | ${car.make} ${car.model}`}>
  <Header />

  <main class="min-h-screen bg-zinc-950 text-white pt-24 pb-12 flex items-center justify-center px-4">
    <div class="w-full max-w-6xl grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
      
      <!-- Left Column: Order Summary -->
      <div class="space-y-8">
        <div>
          <a href={`/auto/${car.id}`} class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors mb-6 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al vehículo
          </a>
          <h1 class="text-4xl font-black text-white mb-2 tracking-tight">Resumen de Compra</h1>
          <p class="text-zinc-400">Estás a un paso de adquirir tu nuevo vehículo.</p>
        </div>

        <div class="bg-zinc-900/40 border border-white/5 rounded-3xl overflow-hidden p-6 shadow-2xl relative">
          <!-- Ambient glow -->
          <div class="absolute -top-24 -right-24 w-64 h-64 bg-rose-600/10 rounded-full blur-[80px]"></div>

          <div class="relative z-10 flex flex-col md:flex-row gap-6 items-center md:items-start">
            <div class="w-full md:w-48 h-32 rounded-2xl overflow-hidden bg-black/50 border border-white/10 flex-shrink-0">
              {car.image ? (
                <img src={car.image} alt={car.model} class="w-full h-full object-cover object-center" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-zinc-600 text-xs">Sin imagen</div>
              )}
            </div>
            
            <div class="flex-1 w-full space-y-4">
              <div>
                <p class="text-rose-500 font-bold text-sm tracking-widest uppercase">{car.year} {car.make}</p>
                <h3 class="text-2xl font-black text-white">{car.model}</h3>
              </div>
              
              <div class="h-px bg-white/10 w-full"></div>
              
              <div class="flex justify-between items-end">
                <span class="text-zinc-400 font-medium">Total a Pagar</span>
                <span class="text-3xl font-bold text-white">{car.price}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-blue-500/10 border border-blue-500/20 rounded-2xl p-4 flex gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <p class="text-sm text-blue-300">
            <strong>Transacción Segura Simulada.</strong> Esto es un ejemplo de pasarela. Los métodos insertados aquí no realizarán cobros reales. Cualquier número de tarjeta será aceptado exitosamente.
          </p>
        </div>
      </div>

      <!-- Right Column: Payment Gateway -->
      <div class="bg-zinc-900/60 backdrop-blur-xl border border-white/10 p-8 sm:p-10 rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.5)] relative">
        <h2 class="text-2xl font-bold text-white mb-6">Información de Pago</h2>
        
        <form id="payment-form" class="space-y-6">
          
          <div class="space-y-4">
            <!-- Card Name -->
            <div>
              <label class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Titular de la Tarjeta</label>
              <input type="text" required placeholder="Nombres Apellidos" class="w-full bg-zinc-950/80 border border-white/10 text-white rounded-xl px-4 py-3.5 focus:outline-none focus:border-rose-500 transition-colors" />
            </div>

            <!-- Card Number -->
            <div>
              <label class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Número de Tarjeta</label>
              <div class="relative">
                <input type="text" required placeholder="0000 0000 0000 0000" maxlength="19" class="w-full bg-zinc-950/80 border border-white/10 text-white rounded-xl pl-4 pr-12 py-3.5 focus:outline-none focus:border-rose-500 transition-colors font-mono tracking-widest" />
                <svg xmlns="http://www.w3.org/2000/svg" class="absolute right-4 top-1/2 -translate-y-1/2 w-6 h-6 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
              </div>
            </div>

            <!-- Expiry & CVV -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Vencimiento</label>
                <input type="text" required placeholder="MM/YY" maxlength="5" class="w-full bg-zinc-950/80 border border-white/10 text-white flex-1 rounded-xl px-4 py-3.5 focus:outline-none focus:border-rose-500 transition-colors font-mono" />
              </div>
              <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1 ml-1">CVV</label>
                <input type="password" required placeholder="•••" maxlength="4" class="w-full bg-zinc-950/80 border border-white/10 text-white rounded-xl px-4 py-3.5 focus:outline-none focus:border-rose-500 transition-colors font-mono" />
              </div>
            </div>
          </div>

          <p id="payment-message" class="text-sm font-semibold text-center hidden"></p>

          <button 
            type="submit" 
            id="pay-btn"
            data-car-id={car.id}
            class="w-full py-4 bg-green-600 hover:bg-green-500 text-white font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-green-600/30 text-lg flex justify-center items-center gap-2 mt-4"
          >
            Pagar {car.price}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </form>

        <div class="mt-8 flex justify-center items-center gap-4 opacity-50 grayscale">
          <!-- Mock logos -->
          <div class="text-xs font-bold italic tracking-widest text-zinc-300">VISA</div>
          <div class="text-xs font-bold italic tracking-widest text-zinc-300">MASTERCARD</div>
          <div class="text-xs font-bold italic tracking-widest text-zinc-300">AMEX</div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const form = document.getElementById('payment-form');
    const payBtn = document.getElementById('pay-btn');
    const payMsg = document.getElementById('payment-message');

    const getCookie = (name: string) => {
      const value = `; ${document.cookie}`;
      const parts = value.split(`; ${name}=`);
      if (parts.length === 2) return parts.pop()?.split(';').shift();
      return null;
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if(!payBtn || !payMsg) return;

      const carId = payBtn.getAttribute('data-car-id');
      const token = getCookie('token');

      if(!token) {
        payMsg.textContent = "Error crítico: Token de autenticación no encontrado.";
        payMsg.className = "text-sm font-semibold text-center mt-4 text-rose-500";
        return;
      }

      const originalBtnContent = payBtn.innerHTML;
      payBtn.setAttribute('disabled', 'true');
      payBtn.classList.remove('bg-green-600', 'hover:bg-green-500');
      payBtn.classList.add('bg-zinc-700', 'cursor-wait');
      payBtn.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Procesando Tarjeta...
      `;

      payMsg.textContent = "Validando fondos de prueba con la pasarela...";
      payMsg.className = "text-sm font-semibold text-center text-blue-400 mt-4";

      // Animación falsa del servidor de pagos (mock de 2 segundos)
      setTimeout(async () => {
        try {
          // Resolver dinámicamente la IP de la Máquina Virtual de Azure
          const baseUrl = window.location.protocol + '//' + window.location.hostname + ':3001';

          // Llamada real al backend para marcarlo como Vendido
          const res = await fetch(`${baseUrl}/api/vehicles/${carId}/buy`, {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            }
          });

          const data = await res.json();

          if (!res.ok) {
            payMsg.textContent = data.error || "La transacción fue denegada por el banco.";
            payMsg.className = "text-sm font-semibold text-center mt-4 text-rose-500";
            payBtn.innerHTML = originalBtnContent;
            payBtn.removeAttribute('disabled');
            payBtn.classList.add('bg-green-600', 'hover:bg-green-500');
            payBtn.classList.remove('bg-zinc-700', 'cursor-wait');
          } else {
            payMsg.className = "text-sm font-semibold text-center mt-4 text-green-400 bg-green-900/40 p-3 rounded-lg border border-green-500/30";
            payMsg.textContent = "¡Pago Aprobado con Éxito! Registrando propietario...";
            payBtn.innerHTML = "¡Compra Cerrada!";
            payBtn.classList.remove('bg-zinc-700', 'cursor-wait');
            payBtn.classList.add('bg-green-500');
            
            // Redirigir al inventario
            setTimeout(() => {
              window.location.href = '/inventario';
            }, 2500);
          }
        } catch (err) {
          payMsg.textContent = "Error de red al contactar al servidor.";
          payMsg.className = "text-sm font-semibold text-center mt-4 text-rose-500";
          payBtn.innerHTML = originalBtnContent;
          payBtn.removeAttribute('disabled');
          payBtn.classList.add('bg-green-600', 'hover:bg-green-500');
          payBtn.classList.remove('bg-zinc-700', 'cursor-wait');
        }
      }, 2000); // Retraso falso de 2 segundos simulando al Banco
    });
  </script>
</Layout>
