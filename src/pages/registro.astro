---
import Layout from '../layouts/Layout.astro';

let isError = false;
let errorMessage = "";

// SSR: Interceptar el POST del formulario de Registro
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name");
    const email = data.get("email");
    const password = data.get("password");
    const confPass = data.get("confirm_password");

    if (password !== confPass) {
      isError = true;
      errorMessage = "Las contraseñas no coinciden.";
    } else {
      // Comunicación Docker-Interna
      const apiUrl = process.env.API_URL || "http://localhost:3001";
      const res = await fetch(`${apiUrl}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, password })
      });

      const json = await res.json();

      if (!res.ok) {
        isError = true;
        errorMessage = json.error || "Ocurrió un error al registrarse.";
      } else {
      // Modo Compatibilidad Máxima para IPs sin HTTPS:
      Astro.cookies.set('token', json.token, { 
        path: '/', 
        maxAge: 60 * 60 * 24 * 7
      });
      return Astro.redirect('/');
    }
  } catch (err) {
    console.error("Error SSR en Registro:", err);
    isError = true;
    errorMessage = "Error de comunicación interna con el servidor Base.";
  }
}
---

<Layout title="Registro | CARROS MOTORS">
  <div class="relative min-h-screen flex items-center justify-center overflow-hidden py-12">
    <!-- Background Gradient / Image -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-zinc-950/80 backdrop-blur-sm z-10"></div>
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1614200187524-dc4b892acf16?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-30 transform scale-105"></div>
      
      <!-- Decorative Glows -->
      <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-rose-600/20 rounded-full blur-[128px] z-10"></div>
      <div class="absolute bottom-1/4 left-1/4 w-96 h-96 bg-rose-900/20 rounded-full blur-[128px] z-10"></div>
    </div>

    <!-- Register Container -->
    <div class="relative z-20 w-full max-w-lg px-6">
      <!-- Back Link -->
      <a href="/login" class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors mb-8 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver a Iniciar Sesión
      </a>

      <!-- Glassmorphic Card -->
      <div class="bg-zinc-900/50 backdrop-blur-xl border border-white/10 p-8 sm:p-10 rounded-3xl shadow-2xl relative overflow-hidden">
        <!-- Top accent line -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-rose-500 to-transparent opacity-50"></div>

        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold tracking-tight text-white mb-2">Crear Cuenta</h1>
          <p class="text-zinc-400 text-sm">Únete a CARROS MOTORS para una experiencia exclusiva.</p>
        </div>

        <form method="POST" class="space-y-5">
          {isError && (
             <div class="bg-rose-900/40 border border-rose-500/50 text-rose-300 text-sm font-medium py-3 px-4 rounded-xl text-center">
               {errorMessage}
             </div>
          )}
          <!-- Name Input -->
          <div class="relative">
            <label for="name" class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Nombre Completo</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Juan Pérez" 
                class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                required
              />
            </div>
          </div>

          <!-- Email Input -->
          <div class="relative">
            <label for="email" class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Correo Electrónico</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="tu@correo.com" 
                class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                required
              />
            </div>
          </div>

          <!-- Password Input -->
          <div class="relative">
            <label for="password" class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Contraseña</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <input 
                type="password" 
                id="password" 
                name="password" 
                placeholder="••••••••" 
                class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                required
              />
            </div>
          </div>

          <!-- Confirm Password Input -->
          <div class="relative">
            <label for="confirm_password" class="block text-xs font-medium text-zinc-400 mb-1 ml-1">Confirmar Contraseña</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-zinc-500 group-focus-within:text-rose-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <input 
                type="password" 
                id="confirm_password" 
                name="confirm_password" 
                placeholder="••••••••" 
                class="w-full bg-zinc-950/50 border border-white/10 text-white text-sm rounded-xl pl-11 pr-4 py-3.5 focus:outline-none focus:border-rose-500 focus:ring-1 focus:ring-rose-500 transition-all"
                required
              />
            </div>
          </div>

          <div class="pt-2">
            <button 
              type="submit" 
              class="w-full py-3.5 px-4 bg-rose-600 hover:bg-rose-500 text-white text-sm font-semibold rounded-xl transition-all duration-300 transform shadow-[0_0_15px_rgba(225,29,72,0.3)] hover:shadow-[0_0_25px_rgba(225,29,72,0.5)] flex justify-center items-center gap-2 disabled:bg-rose-800 disabled:cursor-wait"
              onclick="this.innerText='Validando...'"
            >
              Registrarse
            </button>
          </div>
        </form>

        <div class="mt-8 text-center text-xs text-zinc-500">
          Al registrarte aceptas nuestros <a href="#" class="text-rose-500 hover:text-rose-400 transition-colors">Términos de Servicio</a> y <a href="#" class="text-rose-500 hover:text-rose-400 transition-colors">Política de Privacidad</a>.
        </div>
      </div>
    </div>
  </div>
</Layout>
